# ICPC folders often contain extensionless compiled binaries next to source files.
# Keep source and notes, ignore generated executables.
week-*/*
!week-*/
!week-*/*.cpp
!week-*/*.cc
!week-*/*.cxx
!week-*/*.c
!week-*/*.h
!week-*/*.hpp
!week-*/*.md
!week-*/*.txt
